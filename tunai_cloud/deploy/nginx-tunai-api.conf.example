# TUNAI Cloud — Nginx reverse proxy configuration
# ─────────────────────────────────────────────────────────────────────────────
# NOTE: Use EITHER Apache OR Nginx — not both simultaneously.
# Check which is active: systemctl status apache2 nginx
#
# BEFORE USE:
#   - Replace <TUNAI_API_DOMAIN> with your actual subdomain (e.g. api.tunai.kr)
#   - Replace SSL certificate paths with your actual Let's Encrypt paths
#   - Run: sudo nginx -t              ← validate BEFORE reload
#   - Run: sudo systemctl reload nginx
#
# Install as:
#   /etc/nginx/sites-available/tunai-api
#   sudo ln -s /etc/nginx/sites-available/tunai-api /etc/nginx/sites-enabled/
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP → HTTPS redirect ─────────────────────────────────────────────────────
server {
    listen 80;
    server_name <TUNAI_API_DOMAIN>;
    return 301 https://$host$request_uri;
}

# ── HTTPS ─────────────────────────────────────────────────────────────────────
server {
    listen 443 ssl;
    server_name <TUNAI_API_DOMAIN>;

    # SSL — replace with your Let's Encrypt paths
    ssl_certificate     /etc/letsencrypt/live/<TUNAI_API_DOMAIN>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<TUNAI_API_DOMAIN>/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Request body limit (1MB is generous for this API)
    client_max_body_size 1m;

    # Timeouts — AI provider has up to 20s; give a bit of headroom
    proxy_connect_timeout 10s;
    proxy_read_timeout    30s;
    proxy_send_timeout    10s;

    location / {
        proxy_pass         http://127.0.0.1:8100;
        proxy_http_version 1.1;

        # Pass real client information
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Minimal security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options        "DENY"    always;
    add_header Referrer-Policy        "no-referrer" always;

    # Keep TUNAI API logs separate from other sites
    access_log /var/log/nginx/tunai-api-access.log;
    error_log  /var/log/nginx/tunai-api-error.log;
}
