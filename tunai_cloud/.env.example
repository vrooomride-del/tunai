# TUNAI Cloud AI Orchestrator — environment variables
# Copy to .env and fill in your values. NEVER commit .env.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8100

# AI provider: gemini | openai | claude
AI_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Comma-separated list of allowed CORS origins.
# Leave empty to allow only localhost in development.
# Example: https://api.yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=

REQUEST_TIMEOUT_SECONDS=20
MAX_USER_TEXT_LENGTH=1000
